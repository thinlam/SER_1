{
    "ConnectionStrings": {
        "DefaultConnection": "Server=192.168.1.13\\sql2k16r2, 1439;Initial Catalog=VI_DACDT;user id=vietinfo;password=Vietinfo@#@!;TrustServerCertificate=True;"
    },
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console",
            "Serilog.Sinks.File"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/service-.log",
                    "rollingInterval": "Day",
                    "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {CorrelationId} {Level:u3}] {Username} {Message:lj}{NewLine}{Exception}",
                    "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
                }
            }
        ],
        "Enrich": [
            "FromLogContext",
            "WithThreadId"
        ]
    },
    "AllowedHosts": "*",
    "Jwt": {
        "Issuer": "QLDA",
        "Audience": "QLDA.Client",
        "Key": "12345678901234567890123456789012",
        "ExpiryMinutes": 15,
        "AccessTokenExpiryMinutes": 5,
        "RefreshTokenShortExpiryMinutes": 120,
        "RefreshTokenRememberExpiryDays": 30,
        "PasswordKey": "QLDA_Default_Password_Key",
        "RequireUserIdHeader": true
    }
}