END, [t].[LinhVucId], [t].[NhomDuAnId], [t].[NangLucThietKe], [t].[QuyMoDuAn], [t].[HinhThucQuanLyDuAnId], [t].[LoaiDuAnId], [t].[TongMucDauTu], [t].[TrangThaiDuAnId], [t].[GhiChu], CAST(CONVERT(date, [t].[NgayBatDau]) AS datetimeoffset), [t].[LanhDaoPhuTrachId], [t].[DonViPhuTrachChinhId], [d0].[Id], [d1].[Id], [t0].[ChiuTrachNhiemXuLyId], [t0].[DuAnId], [t].[HinhThucDauTuId], [t].[LoaiDuAnTheoNamId], [d0].[TenBuoc], [d0].[BuocId]
FROM (
    SELECT [d].[Id], [d].[BuocHienTaiId], [d].[ChuDauTuId], [d].[DiaDiem], [d].[DonViPhuTrachChinhId], [d].[DuAnTrongDiem], [d].[GhiChu], [d].[GiaiDoanHienTaiId], [d].[HinhThucDauTuId], [d].[HinhThucQuanLyDuAnId], [d].[Index], [d].[LanhDaoPhuTrachId], [d].[LinhVucId], [d].[LoaiDuAnId], [d].[LoaiDuAnTheoNamId], [d].[MaDuAn], [d].[MaNganSach], [d].[NangLucThietKe], [d].[NgayBatDau], [d].[NhomDuAnId], [d].[QuyMoDuAn], [d].[QuyTrinhId], [d].[TenDuAn], [d].[ThoiGianHoanThanh], [d].[ThoiGianKhoiCong], [d].[TongMucDauTu], [d].[TrangThaiDuAnId]
    FROM [DuAn] AS [d]
    WHERE [d].[IsDeleted] = CAST(0 AS bit) AND [d].[IsDeleted] = CAST(0 AS bit) AND [d].[GiaiDoanHienTaiId] IS NULL AND [d].[BuocHienTaiId] IS NULL AND @__request_SearchDto_NamDuAn_0 >= [d].[ThoiGianKhoiCong] AND ([d].[ThoiGianHoanThanh] IS NULL OR @__request_SearchDto_NamDuAn_0 <= [d].[ThoiGianHoanThanh])
    ORDER BY [d].[Index] DESC
    OFFSET @__p_1 ROWS FETCH NEXT @__p_2 ROWS ONLY
) AS [t]
LEFT JOIN [DuAnBuoc] AS [d0] ON [t].[BuocHienTaiId] = [d0].[Id]
LEFT JOIN [DmBuoc] AS [d1] ON [d0].[BuocId] = [d1].[Id]
LEFT JOIN (
    SELECT [d2].[ChiuTrachNhiemXuLyId], [d2].[DuAnId]
    FROM [DuAnChiuTrachNhiemXuLy] AS [d2]
    WHERE [d2].[Loai] = N'DonViPhoiHop'
) AS [t0] ON [t].[Id] = [t0].[DuAnId]
ORDER BY [t].[Index] DESC, [t].[Id], [d0].[Id], [d1].[Id], [t0].[DuAnId]
