{
    "cSpell.words": [
        "aspose",
        "buocs",
        "datetimeoffset",
        "Dinhs",
        "Dtos",
        "EHSMT",
        "Hinhs",
        "Kems",
        "KHLCNT",
        "LCNT",
        "Mangs",
        "Mucs",
        "Phams",
        "QLDA",
        "Thaus",
        "Toans",
        "Truongs",
        "Ungs",
        "Vons"
    ],
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "*.cs": "${basename}*.cs",
        "*.tsx": "${basename}*, ${basename}.ts, ${basename}.spec.ts, ${basename}.spec.tsx, ${basename}.test.ts, ${basename}.test.tsx, ${basename}.stories.ts, ${basename}.stories.tsx",
        "*.ts": "${basename}*, ${basename}.tsx, ${basename}.spec.ts, ${basename}.spec.tsx, ${basename}.test.ts, ${basename}.test.tsx, ${basename}.stories.ts, ${basename}.stories.tsx",
        "*.jsx": "${basename}*, ${basename}.js, ${basename}.spec.js, ${basename}.spec.jsx, ${basename}.test.js, ${basename}.test.jsx, ${basename}.stories.js, ${basename}.stories.jsx",
        "*.js": "${basename}*, ${basename}.jsx, ${basename}.spec.js, ${basename}.spec.jsx, ${basename}.test.js, ${basename}.test.jsx, ${basename}.stories.js, ${basename}.stories.jsx"
    }
}